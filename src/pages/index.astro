---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import avatar from "@/assets/profile-avatar.png";
import PostPreview from "@/components/blog/PostPreview.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);

const highlightedPosts = allPostsByDate.filter((p) => p.data.pinned).slice(0, 3);
---

<PageLayout meta={{ title: "Home" }}>
	<section class="grid gap-10 md:grid-cols-[1.7fr_1fr] md:items-start">
		<div>
			<p class="text-accent mb-3 font-semibold tracking-wide uppercase">Bamboo Fox / CTF / Security</p>
			<h1 class="title mb-6">Hi, I&apos;m yeee3642.</h1>
			<div class="space-y-4">
				<p>
					A Taiwanese high school student focused on web security, reverse engineering, and crypto.
					I use this site to archive CTF writeups, competition notes, and the occasional security deep
					dive.
				</p>
				<p>
					You can call me <span class="font-semibold">shaobingbujiadan</span>. Most recent highlights
					include FhCTF 2026 rank 1, UTCTF 72nd all clear with TakeKitsune, AIS3 EOF Preliminary rank 3,
					and HITCON Final CTF 2025 rank 1 with Bamboo Fox.
				</p>
			</div>
			<div class="mt-6">
				<SocialList />
			</div>
		</div>
		<aside class="border-global-text/15 bg-global-bg/60 rounded-sm border p-5">
			<div class="mb-4 overflow-hidden rounded-sm border border-black/10 dark:border-white/10">
				<Image alt="yeee3642 avatar" class="h-auto w-full" src={avatar} width={320} />
			</div>
			<dl class="space-y-3 text-xs sm:text-sm">
				<div>
					<dt class="text-gray-500 dark:text-gray-400">Focus</dt>
					<dd class="mt-1 font-semibold">Web / Reverse / Crypto</dd>
				</div>
				<div>
					<dt class="text-gray-500 dark:text-gray-400">Team</dt>
					<dd class="mt-1 font-semibold">Bamboo Fox</dd>
				</div>
				<div>
					<dt class="text-gray-500 dark:text-gray-400">Based in</dt>
					<dd class="mt-1 font-semibold">Taiwan</dd>
				</div>
				<div>
					<dt class="text-gray-500 dark:text-gray-400">Current mission</dt>
					<dd class="mt-1 font-semibold">Document every good challenge solve.</dd>
				</div>
			</dl>
		</aside>
	</section>
	<section class="mt-16">
		<h2 class="title mb-6 text-xl">Competition Highlights</h2>
		<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
			<div class="border-global-text/15 rounded-sm border p-4">
				<p class="text-accent text-xs font-semibold uppercase">2026</p>
				<h3 class="mt-2 font-semibold">FhCTF</h3>
				<p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Rank 1 with McDonalds.</p>
			</div>
			<div class="border-global-text/15 rounded-sm border p-4">
				<p class="text-accent text-xs font-semibold uppercase">2026</p>
				<h3 class="mt-2 font-semibold">UTCTF</h3>
				<p class="mt-2 text-sm text-gray-600 dark:text-gray-400">72nd all clear with TakeKitsune.</p>
			</div>
			<div class="border-global-text/15 rounded-sm border p-4">
				<p class="text-accent text-xs font-semibold uppercase">2026</p>
				<h3 class="mt-2 font-semibold">AIS3 EOF Preliminary</h3>
				<p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Rank 3 with 24 Albert55688.</p>
			</div>
			<div class="border-global-text/15 rounded-sm border p-4">
				<p class="text-accent text-xs font-semibold uppercase">2025</p>
				<h3 class="mt-2 font-semibold">HITCON Final CTF</h3>
				<p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Rank 1 with Bamboo Fox.</p>
			</div>
		</div>
	</section>
	{
		highlightedPosts.length > 0 && (
			<section class="mt-16">
				<h2 class="title mb-6 text-xl">Featured Writeups</h2>
				<ul class="space-y-4" role="list">
					{highlightedPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
							<PostPreview post={p} withDesc />
						</li>
					))}
				</ul>
			</section>
		)
	}
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl"><a href="/posts/">Latest Writeups</a></h2>
		<ul class="space-y-4" role="list">
			{
				latestPosts.map((p) => (
					<li class="grid gap-1 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
						<PostPreview post={p} withDesc />
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
